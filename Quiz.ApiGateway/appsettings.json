{
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "quiz-route": {
        "ClusterId": "quiz-cluster",
        "Match": {
          "Path": "/quiz/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "live-rest-route": {
        "ClusterId": "live-cluster",
        "Match": {
          "Path": "/live/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/{**catch-all}"
          }
        ]
      },
      "live-hub-route": {
        "ClusterId": "live-cluster",
        "Match": {
          "Path": "/hubs/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/hubs/{**catch-all}"
          }
        ]
      },
      "coding-hub-route": {
        "ClusterId": "coding-quiz-cluster",
        "Match": {
          "Path": "/coding-hubs/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/coding-hubs/{**catch-all}"
          }
        ]
      },
      "coding-quiz-route": {
        "ClusterId": "coding-quiz-cluster",
        "Match": {
          "Path": "/coding-quiz/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/coding-quiz/{**catch-all}"
          }
        ]
      },
      "coding-sessions-route": {
        "ClusterId": "coding-quiz-cluster",
        "Match": {
          "Path": "/coding-sessions/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/coding-sessions/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "quiz-cluster": {
        "Destinations": {
          "quiz": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "live-cluster": {
        "Destinations": {
          "live": {
            "Address": "http://localhost:5003/"
          }
        }
      },
      "coding-quiz-cluster": {
        "Destinations": {
          "coding-quiz": {
            "Address": "http://localhost:5225/"
          }
        }
      }
    }
  }
}